{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "accessToken.ts",
        "agentPool.ts",
        "approvalRule.ts",
        "config/index.ts",
        "config/vars.ts",
        "deploymentSchedule.ts",
        "deploymentSettings.ts",
        "driftSchedule.ts",
        "environment.ts",
        "environmentRotationSchedule.ts",
        "environmentVersionTag.ts",
        "getInsightsAccount.ts",
        "getInsightsAccounts.ts",
        "getPolicyPack.ts",
        "getPolicyPacks.ts",
        "index.ts",
        "insightsAccount.ts",
        "oidcIssuer.ts",
        "orgAccessToken.ts",
        "policyGroup.ts",
        "provider.ts",
        "stack.ts",
        "stackTag.ts",
        "team.ts",
        "teamAccessToken.ts",
        "teamEnvironmentPermission.ts",
        "teamStackPermission.ts",
        "templateSource.ts",
        "ttlSchedule.ts",
        "types/enums/index.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "webhook.ts"
    ]
}
