# v2 provider targets. The generator binary is gone — schema and
# metadata are derived in-process from the spec + resource map
# embedded under provider/pkg/embedded. The main Makefile is
# autogenerated from .ci-mgmt.yaml; v2-specific extensions live here.

# Path to the canonical Pulumi Cloud public OpenAPI spec (sibling
# checkout). The pinned copy lives next to the runtime so it can be
# //go:embed-ed without escaping the package directory.
PULUMI_SERVICE_SPEC := ../pulumi-service/pkg/apitype/spec/openapi_public.json
PINNED_SPEC := provider/pkg/embedded/openapi_public.json

# v2 binary's source directory. The runtime //go:embed pulls
# openapi_public.json + resource-map.yaml from provider/pkg/embedded
# at build time.
V2_BIN_DIR := provider/cmd/pulumi-resource-pulumiservice

# Refresh the pinned copy of the public OpenAPI spec from a sibling
# pulumi-service checkout. Run this deliberately; CI can diff the
# result against HEAD to detect drift and open a PR for human review
# (the coverage gate then enforces that any new operations are mapped
# or explicitly excluded before merge).
update_spec:
	@if [ ! -f "$(PULUMI_SERVICE_SPEC)" ]; then \
		echo "error: $(PULUMI_SERVICE_SPEC) not found. Clone pulumi-service as a sibling." >&2; \
		exit 1; \
	fi
	cp "$(PULUMI_SERVICE_SPEC)" "$(PINNED_SPEC)"
	@echo "Refreshed $(PINNED_SPEC) from $(PULUMI_SERVICE_SPEC)"
.PHONY: update_spec

# Coverage gate: every operationId in the spec must be mapped or
# explicitly excluded. Implemented as a Go test on the embedded
# package so `go test ./provider/...` runs it without any extra
# tooling — there is no separate gen binary anymore.
coverage_report: ; @go test -run TestEmbedded_CoverageGate ./provider/pkg/embedded/...
.PHONY: coverage_report

# Strict variant: identical to coverage_report (the test is strict by
# default). Kept as a separate target for ergonomic parity with the
# legacy ".mk/v2.mk" of the two-binary era.
coverage_report_strict: coverage_report
.PHONY: coverage_report_strict

# Build the v2 provider binary. One step: `go build`. The runtime
# //go:embed pulls the spec + resource map from
# provider/pkg/embedded directly, and the binary serves the schema
# lazily via GetSchema (built from those embedded inputs on first
# call). After the build we ask the binary for its merged schema and
# write it to V2_BIN_DIR/schema.json — the main Makefile's
# build_sdks targets read from there to produce language SDKs.
v2_provider:
	@mkdir -p bin
	go build -ldflags "$(LDFLAGS)" -o bin/pulumi-resource-pulumiservice ./$(V2_BIN_DIR)
	pulumi package get-schema ./bin/pulumi-resource-pulumiservice > $(V2_BIN_DIR)/schema.json
.PHONY: v2_provider
