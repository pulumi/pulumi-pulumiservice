# v2 provider targets — OpenAPI-driven generator and spec management.
# The main Makefile is autogenerated from .ci-mgmt.yaml; extensions live here.

# Path to the canonical Pulumi Cloud public OpenAPI spec (sibling checkout).
PULUMI_SERVICE_SPEC := ../pulumi-service/pkg/apitype/spec/openapi_public.json
PINNED_SPEC := provider/spec/openapi_public.json

# Refresh the pinned copy of the public OpenAPI spec from a sibling pulumi-service
# checkout. Run this deliberately; CI can diff the result against HEAD to detect
# drift and open a PR for human review (the coverage gate then enforces that any
# new operations are mapped or explicitly excluded before merge).
update_spec:
	@if [ ! -f "$(PULUMI_SERVICE_SPEC)" ]; then \
		echo "error: $(PULUMI_SERVICE_SPEC) not found. Clone pulumi-service as a sibling." >&2; \
		exit 1; \
	fi
	cp "$(PULUMI_SERVICE_SPEC)" "$(PINNED_SPEC)"
	@echo "Refreshed $(PINNED_SPEC) from $(PULUMI_SERVICE_SPEC)"
.PHONY: update_spec

# v2 generator binary. Distinct from the legacy $(CODEGEN) rule in the main
# Makefile — the v2 binary lives at the same path but builds the new
# OpenAPI-driven codegen from provider/cmd/pulumi-gen-pulumiservice.
# Marked .PHONY so we always rebuild rather than chase a stale sentinel;
# the binary is small and the go cache makes this cheap.
v2_build:
	@mkdir -p bin
	go build -o bin/pulumi-gen-pulumiservice ./provider/cmd/pulumi-gen-pulumiservice
.PHONY: v2_build

# Print a coverage report to bin/coverage-report.md and stdout. Does not fail
# on unmapped operations — use `coverage_report_strict` for CI.
coverage_report: v2_build
	bin/pulumi-gen-pulumiservice coverage --strict=false --spec $(PINNED_SPEC) --map provider/resource-map.yaml --out bin/coverage-report.md
	@head -8 bin/coverage-report.md
.PHONY: coverage_report

# Strict coverage gate for CI: exits non-zero if any operationId is unmapped.
coverage_report_strict: v2_build
	bin/pulumi-gen-pulumiservice coverage --spec $(PINNED_SPEC) --map provider/resource-map.yaml --out bin/coverage-report.md
.PHONY: coverage_report_strict

# Emit both schema.json (for SDK generation) and metadata.json (embedded in
# the runtime provider) from the same resource-map.yaml + OpenAPI spec.
# Also copies the emitted files into the v2 binary's embed location so
# `make v2_provider` picks them up.
V2_BIN_DIR := provider/cmd/pulumi-resource-pulumiservice
v2_gen: v2_build
	bin/pulumi-gen-pulumiservice schema   --spec $(PINNED_SPEC) --map provider/resource-map.yaml --out bin/schema.json
	bin/pulumi-gen-pulumiservice metadata --spec $(PINNED_SPEC) --map provider/resource-map.yaml --out bin/metadata.json
	cp bin/schema.json   $(V2_BIN_DIR)/schema.json
	cp bin/metadata.json $(V2_BIN_DIR)/metadata.json
.PHONY: v2_gen

# Build the provider binary. Runs v2_gen first so the embedded schema +
# metadata are always fresh before linking. This produces the canonical
# binary at bin/pulumi-resource-pulumiservice, same path the main Makefile's
# `provider` target produces — they're now the same binary.
#
# After building, ask the binary for its merged schema (the gen-emitted
# schema plus custom-resource contributions spliced in by the provider
# server) and write it back to V2_BIN_DIR/schema.json. The main Makefile's
# `build_sdks` targets read from that file, and they need the full merged
# shape so custom resources (Stack, DeploymentSettings, StackTag, …) get
# emitted into every language SDK.
v2_provider: v2_gen
	go build -ldflags "$(LDFLAGS)" -o bin/pulumi-resource-pulumiservice ./$(V2_BIN_DIR)
	pulumi package get-schema ./bin/pulumi-resource-pulumiservice > $(V2_BIN_DIR)/schema.json
.PHONY: v2_provider
