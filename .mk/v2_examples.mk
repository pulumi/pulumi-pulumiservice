# v2 example PCL renderer + smoke test.
#
# Picked up automatically via the `include $(wildcard .mk/*.mk)` line at the
# bottom of the autogenerated Makefile, so this file survives ci-mgmt regen.

# Render every examples/v2/*/main.pp into per-language Pulumi projects in
# sibling subdirs (typescript/, python/, go/, csharp/, java/, yaml/).
# Skips dependency installation so the local v2 SDK isn't required to be
# published.
.PHONY: render_v2_examples
render_v2_examples:
	cd provider && go run ./tools/render-examples -dir ../examples/v2

# Lightweight smoke test: succeeds iff every example PCL renders to every
# target language. The render tool exits non-zero on any failure, so this
# doubles as a CI check that the v2 schema, metadata, and PCL programs are
# mutually consistent.
.PHONY: test_v2_examples
test_v2_examples: render_v2_examples
	@echo "OK: rendered all examples/v2/*/main.pp to every target language"
